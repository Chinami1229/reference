@InProceedings{Schaefer1987,
  author   = {Schaefer, Bradley},
  title    = {The Astrophysical Journal, 323 : L47-L49,1987 December 1 © 1987. The American Astronomical Society. All rights reserved. Printed in U.S.A},
  year     = {1987},
  abstract = {The sudden brilliance of a supernova (SN) eruption will be reflected on surrounding dust grains to create a phantom nebula. I present a series of calculations in which the apparent brightness of this "light echo" is predicted for a variety of situations where the dust is part of the interstellar medium (ISM). I find that the supernova 1987A will have a very bright echo off the ISM that may perhaps be visible with binoculars for many years. At a time of 400 days past maximum, the SN 1986G is found to be 2.7 mag brighter than would be predicted by an extrapolation of its light curve. This unique property has an easy explanation as a light echo off the dust in the dust lane of Cen A.},
  file     = {:I\:/マイドライブ/Bibliography/pdf/SN/observation/1987ApJ___323L__47S.pdf:PDF},
  groups   = {typeII},
}

