  abstract      = {Analysis of the massive star properties during C, Ne, O \& Si burning         i.e. the neutrino-cooled stage, leads to the simplified neutrino         emission model. In the framework of this model we have simulated         spectrum of the antineutrinos. Flux normalized according to the         massive star model with explicitly given neutrino luminosity         allow us to predict signal produced in water Cherenkov         detectors. The results are discussed from the point of view of         the possibility of the core-collapse supernova event prediction         in advance of a few days.},
  archiveprefix = {arXiv},
  doi           = {10.48550/arXiv.astro-ph/0405006},
  eprint        = {astro-ph/0405006},
  groups        = {presupernova},
  keywords      = {Astrophysics},
  primaryclass  = {astro-ph},
  url           = {https://ui.adsabs.harvard.edu/abs/2004AcPPB..35.1981O},
}

@Article{Odrzywolek2004a,
  author        = {Odrzywolek, A. and Misiaszek, M. and Kutschera, M.},
  journal       = {Astroparticle Physics},
  title         = {Detection possibility of the pair-annihilation neutrinos from the neutrino-cooled pre-supernova star},
  year          = {2004},
  month         = jun,
  number        = {3},
  pages         = {303-313},
  volume        = {21},
  abstract      = {The signal produced in neutrino observatories by the pair-annihilation         neutrinos emitted from a 20 M $_{{\ensuremath{\odot}}}$ pre-         supernova star at the silicon burning phase is estimated. The         spectrum of the neutrinos with an average energy         {\ensuremath{\sim}}2 MeV is calculated with the use of the Monte         Carlo method. A few relevant reactions for neutrinos and anti-         neutrinos in modern detectors are considered. The most promising         results are from {\ensuremath{\nu}}{\textasciimacron}$_{e}$+         p{\textrightarrow} n+ e$^{+}$ reaction. During the Si-burning         phase we expect 1.27 neutrons/day/kton of water to be produced         by neutrinos from a star located at a distance of 1 kpc. Small         admixture of effective neutron-absorbers as e.g. NaCl or GdCl         $_{3}$ makes these neutrons easily visible because of Cherenkov         light produced by electrons which were hit by         {\ensuremath{\sim}}8 MeV photon cascade emitted by Cl or Gd         nuclei. The estimated rate of neutron production for SNO and         Super-Kamiokande is, respectively, 2.2 and 41 events per day for         a star at 1 kpc. For future detectors UNO and Hyper-Kamiokande         we expect 5.6 and 6.9 events per day even for a star 10 kpc         away. This would make it possible to foresee a massive star         death a few days before its core collapse. Importance of such a         detection for theoretical astrophysics is discussed.},
  archiveprefix = {arXiv},
  doi           = {10.1016/j.astropartphys.2004.02.002},
  eprint        = {astro-ph/0311012},
  groups        = {presupernova},
  keywords      = {Massive stars, Neutrino detection, Pre-supernova evolution, 95.85.Ry, 97.60.-s, 97.60.Bw, 29.40.Ke, Neutrino muon pion and other elementary particles, cosmic rays, Late stages of stellar evolution, Supernovae, Astrophysics},
  primaryclass  = {astro-ph},
  url           = {https://ui.adsabs.harvard.edu/abs/2004APh....21..303O},
}

